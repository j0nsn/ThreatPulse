# ThreatPulse 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 数据库配置 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=threatpulse
DB_PASSWORD=your_database_password_here
DB_NAME=threatpulse

# ===== DeepSeek API（备用，默认已切换为免费方案）=====
# 当前版本默认使用 Google 翻译 + 中文截取的免费方案
# 如需切换回 DeepSeek AI 摘要，修改 deepseek_summarizer.py 中的 generate_summary 指向
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# ===== GitHub API（GitHub 情报爬虫 + Trending）=====
GITHUB_TOKEN=github_pat_your_github_token_here

# ===== JWT 认证 =====
# 可选，也可以使用 .jwt_secret 文件
TP_JWT_SECRET=your_jwt_secret_here
